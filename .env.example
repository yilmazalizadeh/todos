# Copy this file to `.env` (auto-loaded by Docker Compose) and/or `.env.local`
# (loaded into your shell by scripts/load-dotenv.ps1 before `dotnet run`).
#
# Both `.env` and `.env.local` are gitignored — only this example is committed.
# NEVER put real production secrets here; dev/staging/prod secrets live in Vault.

# -----------------------------------------------------------------------------
# Docker Compose substitution vars (read by docker-compose.local.yml / .yml)
# -----------------------------------------------------------------------------

# Host port for the local Postgres container. Change if 5432 is already taken
# on your machine (e.g. a local Postgres service is running).
POSTGRES_LOCAL_PORT=55432

# Host port for the local Vault container.
VAULT_LOCAL_PORT=8200

# Credentials for the local Postgres container (NOT real secrets — only used
# by the dev container and seeded into the local Vault).
POSTGRES_USER=todoservice
POSTGRES_PASSWORD=todoservice_password

# Dev-mode Vault root token (NOT a real secret — local dev only).
VAULT_ROOT_TOKEN=root

# Which secret/todoservice/<env> path the app should read from Vault.
VAULT_ENVIRONMENT=dev

# Host the app uses to reach the local Postgres (the app runs on the host,
# not in a container, so it connects via the published port on localhost).
POSTGRES_HOST_FOR_APP=localhost

# -----------------------------------------------------------------------------
# App runtime vars (read by .NET via scripts/load-dotenv.ps1 -> .env.local)
# -----------------------------------------------------------------------------
# In local dev you typically DO NOT set VAULT_ADDR / VAULT_TOKEN so the app
# skips the Vault configuration source and reads the connection string from
# here instead. Uncomment to point the app at the local Vault dev container.

# ASPNETCORE_ENVIRONMENT=Development
# ConnectionStrings__TodoDb=Host=localhost;Port=55432;Database=todoservice_dev;Username=todoservice;Password=todoservice_password

# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=root
# VAULT_ENVIRONMENT=dev
